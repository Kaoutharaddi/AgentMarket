# ── Anchor / Solana ───────────────────────────────────────────────────────────
.anchor
test-ledger

# ── Rust build artifacts ──────────────────────────────────────────────────────
# Covers root workspace (programs/agentmarket) and risc-zero-v2 workspace.
# Cargo.lock IS committed for binary workspaces (Solana programs, CLI tools).
target/
**/*.rs.bk

# ── Node / Yarn ───────────────────────────────────────────────────────────────
node_modules/
.yarn/
.yarn-integrity

# ── Next.js / TypeScript ──────────────────────────────────────────────────────
# Build output and cache — regenerated by `npm run build` / `next build`.
.next/
out/
*.tsbuildinfo

# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Environment / Secrets ─────────────────────────────────────────────────────
# All .env files are ignored. .env.example IS committed (no secrets inside).
.env
**/.env

# Solana keypair files — never commit private keys
*-keypair.json
wallet.json
id.json
*.key
*.pem

# ── Local tooling config ──────────────────────────────────────────────────────
# ngrok.yml contains local tunnel config; each developer uses their own.
ngrok.yml
.ngrok2/

# ── ZK proof binaries ────────────────────────────────────────────────────────
# Binary proof files generated during testing — not source artifacts.
# risc-zero-v2/audit_proof.json IS committed (demonstrates the system works).
*.bin
/tmp/demo_proof.json

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
