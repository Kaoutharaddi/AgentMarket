# AgentMarket Agent — variables de entorno
# Copia este archivo a .env y rellena los valores.

# Clave privada del agente en base58 (Solana keypair)
AGENT_PRIVATE_KEY=

# RPC endpoint de Solana
RPC_URL=https://api.devnet.solana.com

# Helius API key para webhooks de eventos on-chain
HELIUS_API_KEY=

# Ruta al binario del host RISC Zero (relativa al directorio raíz del repo)
ZK_HOST_BINARY=./risc-zero-v2/target/release/agentmarket-audit-host

# Bonsai API (RISC Zero) — requerido para generar Groth16 proofs en producción.
# Sin esta clave, el agente usa RISC0_DEV_MODE=1 (proofs no verificables on-chain).
BONSAI_API_KEY=
BONSAI_API_URL=https://api.bonsai.xyz

# Claude API (Anthropic) — opcional, mejora la detección de vulnerabilidades.
ANTHROPIC_API_KEY=
